<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="AvaloniaApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Работа с Множеством (Set&lt;string&gt;)">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<StackPanel Margin="20" Spacing="15">
		<TextBlock Text="Управление Множеством (Set&lt;string&gt;)"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   FontSize="18"/>

		<Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="5">
			<StackPanel Spacing="10">
				<TextBlock Text="Введите элемент:"/>
				<TextBox Text="{Binding InputValue}" Watermark="Например: Яблоко"/>
				<Grid ColumnDefinitions="*,*,*,*">
					<Button Grid.Column="0" Content="Добавить" Command="{Binding AddCommand}" Margin="0,0,3,0"/>
					<Button Grid.Column="1" Content="Удалить" Command="{Binding RemoveCommand}" Margin="3,0,3,0"/>
					<Button Grid.Column="2" Content="Проверить" Command="{Binding CheckCommand}" Margin="3,0,3,0"/>
					<Button Grid.Column="3" Content="Очистить" Command="{Binding ClearCommand}" Margin="3,0,0,0"/>
				</Grid>
			</StackPanel>
		</Border>

		<Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="5">
			<StackPanel Spacing="5">
				<TextBlock Text="Состояние множества:" FontWeight="Bold"/>
				<TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
				<StackPanel Orientation="Horizontal" Spacing="15">
					<TextBlock>
						<Run Text="Мощность (Count): "/>
						<Run Text="{Binding SetCount}" FontWeight="Bold"/>
					</TextBlock>
					<TextBlock>
						<Run Text="Пустое (IsEmpty): "/>
						<Run Text="{Binding IsSetEmpty}" FontWeight="Bold"/>
					</TextBlock>
				</StackPanel>
			</StackPanel>
		</Border>

		<Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="5" VerticalAlignment="Stretch">
			<StackPanel>
				<TextBlock Text="Элементы множества:" FontWeight="Bold" Margin="0,0,0,5"/>
				<ListBox ItemsSource="{Binding ElementsList}"
                         Height="200">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding}"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"/>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</StackPanel>
		</Border>
	</StackPanel>
</Window>